APP_NAME="LLM TimesFM Crypto"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://llm-timesfm.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# PHP_CLI_SERVER_WORKERS=4

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_BUSY_TIMEOUT=5000
DB_JOURNAL_MODE=WAL
DB_SYNCHRONOUS=NORMAL

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=
CRYPTO_CACHE_ENABLED=true
CRYPTO_CACHE_STORE="${CACHE_STORE}"
CRYPTO_CACHE_ASSETS_SECONDS=1
CRYPTO_CACHE_SELECTED_ASSET_SECONDS=1
CRYPTO_CACHE_MARKET_HISTORY_SECONDS=2
CRYPTO_CACHE_SNAPSHOTS_SECONDS=1
CRYPTO_CACHE_LATEST_FORECAST_SECONDS=3
CRYPTO_CACHE_FORECAST_STATS_SECONDS=2
CRYPTO_CACHE_PREDICTION_STAKES_SECONDS=1
CRYPTO_CACHE_WARM_AFTER_TICKER_SYNC=true
CRYPTO_CACHE_WARM_LIMIT=3
CRYPTO_CACHE_WARM_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
CRYPTO_CACHE_WARM_INTERVALS=1m,5m

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

VITE_APP_NAME="${APP_NAME}"

BINANCE_API_BASE_URL=https://api.binance.com
CRYPTO_MARKET_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT,DOGEUSDT,ADAUSDT,AVAXUSDT,LINKUSDT,TRXUSDT,TONUSDT,DOTUSDT,MATICUSDT,LTCUSDT,BCHUSDT,UNIUSDT,ATOMUSDT,ETCUSDT,FILUSDT,APTUSDT
CRYPTO_MARKET_LIMIT=20
CRYPTO_MARKET_POLL_SECONDS=1
CRYPTO_MARKET_HISTORY_LIMIT=240
CRYPTO_SHORT_INTERVALS=1m,5m
CRYPTO_MAX_KLINE_LIMIT=1000

TIMESFM_ENABLED=false
TIMESFM_PYTHON=.venv/bin/python
TIMESFM_SCRIPT=python/timesfm_forecast.py
TIMESFM_MODEL_ID=google/timesfm-2.5-200m-pytorch
TIMESFM_TIMEOUT=180
TIMESFM_MAX_CONTEXT=512
TIMESFM_MAX_HORIZON=256
